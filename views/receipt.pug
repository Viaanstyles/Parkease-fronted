extends layout
block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 450px;')
      .card-body.p-5
        h2.text-center.fw-bold.mb-2 Park Ease
        p.text-center.text-muted.mb-4 Intergrated Parking System
        h5.fw-bold.text-uppercase Official receipt 
        p.mb-0.font-monospace= record.receiptNumber

        //- Transaction details
        P= 'Date:' + new Date(record.signoutTime).toLocaleDateString()
        P.fw-semibold= 'Time: ' + new Date(record.signoutTime).toLocaleTimeString([], {hour: "2-digit", minute: "2-digit"})
        P.fw-semibold= 'Vehicle Numberplate: ' +  record.vehicleId.numberPlate
        P.fw-semibold= 'Vehicle Type: ' + record.vehicleId.vehicleType
        P.fw-semibold= 'Receiver Name: ' + record.receiverName

        //- Financials
        P.fw-bold.text-uppercase= 'Total Paid UGX: ' + record.amountPaid.toLocaleString()

        //- Footer note
    .text-center.mt-4.mb-4 
        p.small.text-muted.mb-0 Thank you for using ParkEase!
        p.small.text-muted Drive Safely

        //- Print Receipt
    .card.footer.bg-white.border-0.p-4.pt-0.no-print 
        button.btn.btn-primary.w-100.py-2.fw-bold.mb-2(onclick="window.print()")
            i.fa-solid.fa-print.me-2
            | Print Receipt 
        


  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
