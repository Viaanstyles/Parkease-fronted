extends layout

block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center(style="background:linear-gradient(135deg,#eef2f7,#f8f9fb);")
    
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 460px;')
      .card-body.p-5

        // HEADER
        h2.text-center.fw-bold.mb-2(style="color:#333;") Battery Service
        p.text-center.text-muted.mb-4(style="font-size:14px;") Select battery and transaction details

        // FORM
        form(method='post' action='/batteryServices')

          // Select Battery
          .mb-3
            label.form-label.fw-semibold(for='batteryId') Select Battery
            select#batteryId.form-select.rounded-3(name="batteryId" style="padding:10px;")
              option(value="" selected disabled) Choose battery
              if availableBatteries && availableBatteries.length > 0
                each battery in availableBatteries
                  option(value=battery._id) #{battery.batteryType} - #{battery.batterySize}

          // Transaction Type
          .mb-3
            label.form-label.fw-semibold(for='transactionType') Transaction Type
            select#transactionType.form-select.rounded-3(name="transactionType" style="padding:10px;")
              option(value="") Select Transaction
              option(value="Hire") Hire
              option(value="Sale") Sale

          // Number Plate
          .mb-3
            label.form-label.fw-semibold(for='numberPlate') Number Plate
            input#numberPlate.form-control.rounded-3(
              type='text' 
              name='numberPlate' 
              placeholder='e.g UBA 123A'
              style="padding:10px;"
            )

          // Price Display
          .mb-4
            label.form-label.fw-semibold(for='price') Price
            input#price.form-control.rounded-3(
              type='number' 
              name='price' 
              style="padding:10px;"
            )

          // SUBMIT BUTTON
          button.btn.w-100.py-2.fw-bold.rounded-3(
            type='submit'
            style="background:#007BFF; border:none;"
          ) Done

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')