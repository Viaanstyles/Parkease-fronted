extends layout

block content 
  div(style="padding:25px; background:#f4f6f9; min-height:100vh; font-family:Arial, sans-serif;")

    // TOP BAR
    .dashboard-top(style="display:flex; justify-content:flex-end; margin-bottom:20px;")
      .search-wrapper
        input.dashboard-search(
          type='text' 
          placeholder='Search vehicle by number plate...'
          style="padding:10px 15px; width:280px; border-radius:25px; border:1px solid #ccc; outline:none; box-shadow:0 2px 6px rgba(0,0,0,0.08);"
        )

    .dashboard-container(style="max-width:1200px; margin:auto;")

      // STAT CARDS
      .stats(style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:20px; margin-bottom:25px;")
        
        .card(style="background:white; padding:20px; border-radius:12px; box-shadow:0 4px 10px rgba(0,0,0,0.08);")
          h3(style="color:#666; margin-bottom:10px;") Parked Vehicles
          p(style="font-size:24px; font-weight:bold; color:#007BFF; margin:0;") #{vehicles.length}

        
        .card(style="background:white; padding:20px; border-radius:12px; box-shadow:0 4px 10px rgba(0,0,0,0.08);")
          h3(style="color:#666; margin-bottom:10px;") Available Slots
          p(style="font-size:24px; font-weight:bold; color:#ffc107; margin:0;")=100 - vehicles.length 
 

        
      // QUICK ACTIONS
      .quick-actions(style="display:flex; gap:15px; margin-bottom:25px;")
        a(href='/registerVehicle')
          button(
            style="padding:10px 20px; border:none; background:#007BFF; color:white; border-radius:6px; cursor:pointer; font-weight:bold;"
          ) Register Vehicle

        a(href='/signout')
          button(
            style="padding:10px 20px; border:none; background:#dc3545; color:white; border-radius:6px; cursor:pointer; font-weight:bold;"
          ) Vehicle Sign Out

      // TABLE
      .table-container(style="background:white; padding:20px; border-radius:12px; box-shadow:0 4px 10px rgba(0,0,0,0.08); overflow-x:auto;")
        table(style="width:100%; border-collapse:collapse; min-width:900px;")
          thead(style="background:#007BFF; color:white;")
            tr
              th(style="padding:12px; text-align:left;") Image
              th(style="padding:12px; text-align:left;") Driver Name
              th(style="padding:12px; text-align:left;") Phone Number
              th(style="padding:12px; text-align:left;") Vehicle Type
              th(style="padding:12px; text-align:left;") Number Plate
              th(style="padding:12px; text-align:left;") Vehicle Model
              th(style="padding:12px; text-align:left;") Vehicle Color
              th(style="padding:12px; text-align:left;") Arrival Time
              th(style="padding:12px; text-align:left;") Status
              th(style="padding:12px; text-align:left;") Receipt
              th(style="padding:12px; text-align:left;") Action

          tbody
            if vehicles.length 
              each vehicle in vehicles 
                tr(style="border-bottom:1px solid #eee;")
                  td(style="padding:10px;")
                    img(
                      src="/" + vehicle.vehicleImage 
                      alt="Vehicle image" 
                      width="120px" 
                      height="100px"
                      style="border-radius:8px; object-fit:cover;"
                    )
                  td(style="padding:10px;") #{vehicle.driverName}
                  td(style="padding:10px;") #{vehicle.phoneNumber}
                  td(style="padding:10px;") #{vehicle.vehicleType}
                  td(style="padding:10px; font-weight:bold;") #{vehicle.numberPlate}
                  td(style="padding:10px;") #{vehicle.vehicleModel}
                  td(style="padding:10px;") #{vehicle.vehicleColor}
                  td(style="padding:10px;") #{vehicle.arrivalTime}
                  td(style="padding:10px; color:#28a745; font-weight:bold;") #{vehicle.status}  
                  td(style="padding:10px;") #{vehicle.receiptNumber} 
                  td(style="padding:10px;")
                    button(
                      onclick=`navigator.clipboard.writeText("${vehicle.receiptNumber}"); alert("Receipt ${vehicle.receiptNumber} copied");`
                      style="padding:6px 10px; border:none; background:#17a2b8; color:white; border-radius:5px; cursor:pointer;"
                    ) Copy      

            else 
              tr 
                td(colspan="11" style="padding:15px; text-align:center; color:#888;")
                  | No vehicles found

  script(src='javaScript/dashboard.js')