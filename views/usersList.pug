extends layout 
block content      
    table
        thead
            tr
                th First Name
                th Last Name
                th Email
                th PhoneNumber
                th Role
                th Update
                th Delete
        tbody
            if users.length 
                each user in users 
                    tr
                        td #{user.firstName}
                        td #{user.lastName}
                        td #{user.email}
                        td #{user.phoneNumber}
                        td #{user.role}
                        td 
                            a.btn.btn-sm.btn-outline-warning.text-dark(href=`/users/update/${user._id}`)
                                i.fa-solid.fa-pen-to-square 
                        td 
                            form(method="post", action="/users/delete")
                                input(type="hidden", name="id", value=user._id)
                                button.btn.btn-sm.btn-outline-danger.text-dark(type="submit")
                                    i.fa-solid.fa-trash
            else 
                tr 
                    td No users found            
                