extends layout

block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center(style="background:linear-gradient(135deg,#eef2f7,#f8f9fb);")

    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 460px;')
      .card-body.p-5

        // HEADER
        h2.text-center.fw-bold.mb-2(style="color:#333;") Tyre Services
        p.text-center.text-muted.mb-4(style="font-size:14px;") Enter tyre details and service type

        form(method='post' action='/tyreServices')

          // Tyre Type
          .mb-3
            label.form-label.fw-semibold(for='tyreType') Tyre Brand
            select#tyreType.form-select.rounded-3(name="tyreType" style="padding:10px;")
              option(value="") Select tyre brand
              option(value="Bridgestone") Bridgestone
              option(value="Goodyear") Goodyear
              option(value="CEAT") CEAT
              option(value="Continental") Continental

          // Tyre Size
          .mb-3
            label.form-label.fw-semibold(for='tyreSize') Tyre Size
            select#tyreSize.form-select.rounded-3(name="tyreSize" style="padding:10px;")
              option(value="") Select tyre size
              option(value="15 Inch") 15 Inch
              option(value="16 Inch") 16 Inch
              option(value="17 Inch") 17 Inch

          // Tyre Service
          .mb-3
            label.form-label.fw-semibold(for='tyreServices') Service Type
            select#tyreServices.form-select.rounded-3(name="tyreServices" style="padding:10px;")
              option(value="") Select service
              option(value="Pressure") Pressure
              option(value="Puncture-fixing") Puncture Fixing
              option(value="Valves") Valves

          // Price
          .mb-4
            label.form-label.fw-semibold(for='tyrePrice') Price (UGX)
            input#tyrePrice.form-control.rounded-3(
              type='number' 
              placeholder='e.g 10000' 
              name='tyrePrice'
              style="padding:10px;"
            )

          // BUTTON
          button.btn.w-100.py-2.fw-bold.rounded-3(
            type='submit'
            style="background:#007BFF; border:none;"
          ) Register Tyre

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')