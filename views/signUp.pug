extends layout
block content
    .container.min-vh-100.d-flex.justify-content-center.align-items-center
        .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 500px;')
            .card-body.p-5
                h2.text-center.fw-bold.mb-4 Create an Account
                form(method='post' action='/signup')
                    .row.mb-3
                        .col-md-6.mb-3.mb-md-0
                            label.form-label.fw-semibold(for='firstName') First Name
                            input#firstName.form-control(type='text' placeholder='John' name='firstName')
                        .col-md-6
                            label.form-label.fw-semibold(for='lastName') Last Name
                            input#lastName.form-control(type='text' placeholder='Doe' name='lastName')
                    .mb-3
                        label.form-label.fw-semibold(for='email') Email Address
                        input#email.form-control(type='email' placeholder='name@example.com' name='email')
                    .mb-3
                        label.form-label.fw-semibold(for='phone') Phone Number
                        input#phone.form-control(type='tel' placeholder='+256 700 000000' name='phoneNumber')
                    .mb-3
                        label.form-label.fw-semibold(for='role') Role
                        select#role(name="role")
                            option(value="") Select role 
                            option(value="Admin") Admin 
                            option(value="Manager") Manager 
                            option(value="Attendant") Attendant   
                    .mb-4
                        label.form-label.fw-semibold(for='password') Password
                        input#password.form-control(type='password' placeholder='••••••••' name='password')
                        .form-text Must be at least 8 characters long.
                    button.btn.btn-primary.w-100.py-2.fw-bold.rounded-3(type='submit') Register User
                    //- .text-center.mt-4
                    //-     p.mb-0.text-muted
                    //-         | Already have an account? 
                    //-         a.text-decoration-none(href='/auth/login') Log in
            script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
