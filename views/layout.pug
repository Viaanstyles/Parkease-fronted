doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Log In
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/style.css')
body.dashboard-page
  div.nav-set
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container-fluid
        a.navbar-brand(href='/login') ParkEase
        #navbarSupportedContent.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            if user 
              if user.role === "Admin"
                li.nav-item 
                  a.nav-link(href="/admin") Dashboard
                li.nav-item 
                  a.nav-link(href="/usersList") Manage Users
              if user.role === "Manager"
                li.nav-item 
                  a.nav-link(href="/manager") Dashboard
                li.nav-item 
                  a.nav-link(href="/registerBattery") Add Battery 
                li.nav-item 
                  a.nav-link(href="/batteryServices") Battery Transaction
                li.nav-item 
                  a.nav-link(href="/tyreServices") Tyre Clinic
              if user.role === "Attendant"
                li.nav-item 
                  a.nav-link(href="/attendant") Dashboard
                li.nav-item 
                  a.nav-link(href="/registerVehicle") Check in
                  li.nav-item 
                  a.nav-link(href="/signout") Check out
          div.d-flex.ms-lg-3.align-items-center
            if user 
              span.text-light.me-3.small 
                i.fa-solid.fa-user-circle.me-1 
                | Hi, #{user.firstName}
                span.badge.bg-secondary.ms-1 #{user.role}
              a.btn.btn-outline-danger.btn-sm.fw-bold(href="/logout") Log Out
            else 
              a.btn.btn-outline.light.me-2(href="/login") Log in
    block content
  br 
  footer.bg-dark.text-white.py-4.mt-auto 
    .container.text-center 
      p.mb-0 &copy;  2026 Nakayongo Sylvia. All Rights Reserved
